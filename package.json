{
  "name": "jobby-app",
  "private": true,
  "version": "1.0.0",
  "dependencies": {
    "@testing-library/jest-dom": "5.11.9",
    "@testing-library/react": "11.2.5",
    "@testing-library/user-event": "12.6.2",
    "ajv": "8.20.0",
    "ajv-keywords": "5.1.0",
    "chalk": "4.1.0",
    "js-cookie": "^3.0.5",
    "msw": "0.28.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-icons": "^5.5.0",
    "react-loader-spinner": "4.0.0",
    "react-router-dom": "^6.28.0"
  },
  "devDependencies": {
    "husky": "4.3.8",
    "lint-staged": "10.5.4",
    "npm-run-all": "4.1.5",
    "prettier": "2.2.1",
    "react-scripts": "5.0.1"
  },
  "scripts": {
  "start": "react-scripts start",
  "build": "set CI=false && set DISABLE_ESLINT_PLUGIN=true && react-scripts build",
  "test": "react-scripts test",
  "lint": "eslint .",
  "lint:fix": "eslint --fix src/",
  "format": "prettier --write \"./src\"",
  "run-all": "npm-run-all --parallel test lint:fix"
},
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged"
    }
  },
  "jest": {
    "collectCoverageFrom": [
      "src/**/*.js",
      "src/**/*.jsx"
    ]
  },
  "browserslist": {
    "development": [
      "last 2 chrome versions",
      "last 2 firefox versions",
      "last 2 edge versions"
    ],
    "production": [
      ">1%",
      "last 4 versions",
      "Firefox ESR",
      "not ie < 11"
    ]
  }
}
